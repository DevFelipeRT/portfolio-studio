# -------------------------------------------------------------------
# User mapping
# Host user and group identifiers used for container file ownership.
# -------------------------------------------------------------------
UID=1000
GID=1000

# -------------------------------------------------------------------
# Application settings
# Runtime flags propagated to application containers.
# -------------------------------------------------------------------
APP_ENV=local
APP_DEBUG=true
TZ=UTC

# -------------------------------------------------------------------
# MySQL settings
# Database service credentials and port mapping.
# -------------------------------------------------------------------
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_PORT=3306
DB_SEED_ON_BOOT=false

# -------------------------------------------------------------------
# Nginx settings
# Public HTTP port and server name used by the web container.
# -------------------------------------------------------------------
NGINX_PORT=8080
SERVER_NAME=localhost

# -------------------------------------------------------------------
# Vite settings
# Development server port and Node.js runtime mode.
# -------------------------------------------------------------------
VITE_PORT=5173
NODE_ENV=development

# -------------------------------------------------------------------
# PHP-FPM settings
# Internal PHP-FPM listening port exposed to the web container.
# -------------------------------------------------------------------
PHP_FPM_PORT=9000
