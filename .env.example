# Baseline variables for the default local runtime are left uncommented.
# Commented variables are supported by the application and become effective when
# the related driver, transport, or feature is selected in this environment.

APP_NAME="Portfolio Studio"
APP_ENV=local
# Base64-encoded application key generated with `php artisan key:generate`.
APP_KEY=
# Comma-separated list of previous keys used for cookie and payload decryption.
# APP_PREVIOUS_KEYS=
APP_DEBUG=true
# Canonical application URL used for links, asset URLs, and mail defaults.
APP_URL=http://localhost

# Default locale settings used by the application, translations, and data generation.
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Cookie names used to persist public and system locale preferences.
# APP_SYSTEM_LOCALE_COOKIE=system_locale
# APP_PUBLIC_LOCALE_COOKIE=public_locale

# Maintenance mode storage configuration.
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# --- Frontend dev server (Vite) ---
# Development server network binding and port used by Vite during local development.
VITE_PORT=5173
VITE_BIND=0.0.0.0

# --- Logging ---
# Default logging channel and severity configuration.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# LOG_DEPRECATIONS_TRACE=false
LOG_LEVEL=debug

# --- Database ---
# Primary relational database connection settings.
DB_CONNECTION=mysql
# Full connection URL supported by Laravel database drivers.
# DB_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
# Unix socket path for local MySQL connections.
# DB_SOCKET=
# Character set and collation used by MySQL and MariaDB connections.
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# Foreign key enforcement for SQLite connections.
# DB_FOREIGN_KEYS=true

# --- Session / Cache / Queue / Filesystem ---
# Runtime drivers used for sessions, cache, queue processing, and filesystem storage.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_EXPIRE_ON_CLOSE=false
# SESSION_CONNECTION=
# SESSION_TABLE=sessions
# SESSION_STORE=
# SESSION_SECURE_COOKIE=true
# SESSION_HTTP_ONLY=true
# SESSION_SAME_SITE=lax
# SESSION_PARTITIONED_COOKIE=false

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# QUEUE_FAILED_DRIVER=database-uuids
CACHE_STORE=database
# CACHE_PREFIX=

# Database-backed cache and queue table configuration.
# DB_CACHE_CONNECTION=
# DB_CACHE_TABLE=cache
# DB_CACHE_LOCK_CONNECTION=
# DB_CACHE_LOCK_TABLE=
# DB_QUEUE_CONNECTION=
# DB_QUEUE_TABLE=jobs
# DB_QUEUE=default
# DB_QUEUE_RETRY_AFTER=90

# --- Redis / Memcached ---
# Connection settings for Redis-backed cache, queue, session, and lock drivers.
# REDIS_CLIENT=phpredis
# REDIS_CLUSTER=redis
# REDIS_PREFIX=
# REDIS_PERSISTENT=false
# REDIS_URL=
# REDIS_HOST=127.0.0.1
# REDIS_USERNAME=
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1
# REDIS_CACHE_CONNECTION=cache
# REDIS_CACHE_LOCK_CONNECTION=default
# REDIS_QUEUE_CONNECTION=default
# REDIS_QUEUE=default
# REDIS_QUEUE_RETRY_AFTER=90
# REDIS_MAX_RETRIES=3
# REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
# REDIS_BACKOFF_BASE=100
# REDIS_BACKOFF_CAP=1000
# MEMCACHED_HOST=127.0.0.1

# --- Mail ---
# Mail transport, sender identity, and application notification recipients.
MAIL_MAILER=log

# Default sender identity for outgoing mail.
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Recipient used for contact form notifications.
MAIL_TO_ADDRESS=
MAIL_TO_NAME=

# SMTP transport settings.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# MAIL_SCHEME=tls
# MAIL_URL=
# MAIL_EHLO_DOMAIN=

# Postmark transport credentials.
# POSTMARK_API_KEY=

# Resend transport credentials.
# RESEND_API_KEY=

# Amazon SES transport credentials are shared with the S3 integration.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Sendmail transport path.
# MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs -i"

# Log mailer channel override.
# MAIL_LOG_CHANNEL=

# --- Inertia ---
# Server-side rendering and history encryption settings for Inertia.
# INERTIA_SSR_ENABLED=false
# INERTIA_SSR_URL=http://127.0.0.1:13714
# INERTIA_SSR_ENSURE_BUNDLE_EXISTS=true
# INERTIA_ENCRYPT_HISTORY=false

# --- Rich text (Lexical JSON) ---
# Maximum serialized rich-text payload size, in bytes, after normalization.
RICH_TEXT_MAX_PAYLOAD_BYTES=67108864

# --- AWS / S3 ---
# Object storage credentials and endpoint settings for the S3 filesystem driver.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Authentication ---
# Authentication guard, password broker, and password confirmation timeout.
# AUTH_GUARD=web
# AUTH_PASSWORD_BROKER=users
# AUTH_MODEL=App\\Modules\\IdentityAccess\\Domain\\Models\\User
# AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
# AUTH_PASSWORD_TIMEOUT=10800
